{
  "name": "requirement",
  "contract_version": 1,
  "produces_kind": "document",
  "parameters": [
    { "name": "id",       "type": "string", "required": true },
    { "name": "title",    "type": "string", "required": true },
    { "name": "priority", "type": "string", "required": false, "default": "p2" }
  ],
  "output_path": "docs/requirements/{{ id }}.md"
}
