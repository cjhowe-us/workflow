{
  "SessionStart": [
    {
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sessionstart-env-check.sh",
      "timeout": 10
    }
  ],
  "SubagentStop": [
    {
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/release-lock-on-stop.sh",
      "timeout": 30
    },
    {
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/unblock-scan-on-idle.sh",
      "timeout": 10
    }
  ],
  "TaskCompleted": [
    {
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/release-lock-on-stop.sh",
      "timeout": 30
    },
    {
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/unblock-scan-on-idle.sh",
      "timeout": 10
    }
  ],
  "TeammateIdle": [
    {
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/unblock-scan-on-idle.sh",
      "timeout": 10
    }
  ]
}
